ATRIUM_HOST=0.0.0.0
ATRIUM_PORT=3000
ATRIUM_DATA_DIR=/data
ATRIUM_BASE_URL=https://knowledge.example.com
ATRIUM_SECURE_COOKIES=true

# Optional invitation and password recovery email delivery.
# Without this, recovery links are written to stdout and invitation links remain
# available for owners to copy.
ATRIUM_RESEND_API_KEY=
ATRIUM_MAIL_FROM=Atrium <knowledge@example.com>

# Optional OpenID Connect SSO.
ATRIUM_OIDC_ISSUER=https://identity.example.com
ATRIUM_OIDC_CLIENT_ID=
ATRIUM_OIDC_CLIENT_SECRET=
ATRIUM_OIDC_AUTO_PROVISION=false
